[Unit]
Description=Stroopwafel: Social Media Manager Scheduler Runner
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=www-data
Group=www-data
WorkingDirectory=/opt/stroopwafel
EnvironmentFile=/etc/stroopwafel.env
ExecStart=/usr/local/bin/stroopwafel-scheduler
StandardOutput=journal
StandardError=journal
